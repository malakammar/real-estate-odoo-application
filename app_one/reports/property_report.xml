<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>

        <!-- TREE VIEW -->
        <record id="property_view_tree" model="ir.ui.view">
            <field name="name">property tree</field>
            <field name="model">property</field>
            <field name="arch" type="xml">
                <tree multi_edit="1" create="1" edit="1" delete="1">

                    <field name="name"/>
                    <field name="owner_id"/>
                    <field name="owner_address"/>
                    <field name="owner_phone"/>
                    <field name="data_availability"/>
                    <field name="selling_price"/>
                    <field name="garden"/>
                    <field name="garden_area"/>
                    <field name="garden_orientation"/>
                    <field name="accepted_price"/>
                    <field name="diff"/>
                    <field name="garage"/>
                    <field name="living_area"/>
                    <field name="state"/>
                    <field name="bedrooms"/>
                    <field name="tag_ids"/>
                    <field name="is_late"/>
                    <field name="expected_selling_date"/>

                </tree>
            </field>
        </record>


        <!-- FORM VIEW -->
        <record id="property_view_form" model="ir.ui.view">
            <field name="name">Property Form</field>
            <field name="model">property</field>
            <field name="arch" type="xml">

                <form>
                    <sheet>

                        <header>
                            <button name="action" type="object" string="Action"/>
<button name="action_draft" type="object" string="Set To Draft"
                                    class="btn-primary"
                                    invisible="state == 'draft'"/>

                            <button name="action_pending" type="object" string="Set To Pending"
                                    class="btn-secondary"
                                    invisible="state != 'draft'"/>

                            <button name="action_sold" type="object" string="Set To Sold"
                                    class="btn-success"
                                    invisible="state != 'pending'"/>

                            <field name="state"
                                   widget="statusbar"
                                   statusbar_visible="draft,pending,sold,closed"/>
                        </header>


                        <div class="oe_title">
                            <label for="name"/>
                            <h1><field name="name"/></h1>
                        </div>


                        <group>
                            <group string="General info">
                                <field name="owner_address"/>
                                <field name="owner_phone"/>
                                <field name="data_availability"/>
                                <field name="owner_id"/>
                                <field name="selling_price"/>
                                <field name="diff"/>
                                <field name="garden"/>
                                <field name="post_code"/>
                            </group>

                            <group string="Additional info">
                                <field name="garage"/>
                                <field name="living_area"/>
                                <field name="bedrooms"/>
                            </group>

                            <group>
                                <field name="garden_area"/>
                                <field name="garden_orientation"/>
                                <field name="accepted_price"/>
                                <field name="tag_ids" widget="many2many_tags"/>
                            </group>
                        </group>


                        <!-- ONE2MANY -->
                        <notebook>
                            <page string="Bedrooms">

                                <field name="line_ids">
                                    <tree editable="bottom">
                                        <field name="description"/>
                                        <field name="area"/>
                                    </tree>
                                </field>

                            </page>
                        </notebook>

                    </sheet>


                    <!-- CHATER -->
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>

                </form>

            </field>
        </record>


        <!-- ACTION WINDOW -->
        <record id="property_action" model="ir.actions.act_window">
            <field name="name">Properties</field>
            <field name="res_model">property</field>
            <field name="view_mode">tree,form</field>
        </record>


        <!-- SERVER ACTION -->
        <record id="property_closed_action" model="ir.actions.server">
            <field name="name">Close Property</field>
            <field name="model_id" ref="model_property"/>
            <field name="binding_model_id" ref="model_property"/>
            <field name="state">code</field>
            <field name="code">
action = records.action_close()
            </field>
        </record>


        <!-- CRON JOB -->
        <record id="check_selling_date_cron" model="ir.cron">
            <field name="name">Property: check selling date</field>
            <field name="model_id" ref="model_property"/>
            <field name="state">code</field>
            <field name="code">model.check_selling_date()</field>

            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>


        <!-- MENU -->
        <menuitem id="property_menu_item"
                  name="Properties"
                  parent="properties_menu"
                  action="property_action"/>

    </data>

</odoo>